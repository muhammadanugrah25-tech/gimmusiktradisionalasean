    },
    { 
      question: "Angklung adalah alat musik tiup bambu tradisional dari...",
      options: ["Laos", "Thailand", "Indonesia", "Vietnam"],
      answer: "Indonesia"
    },
    { 
      question: "Rebab adalah alat musik gesek tradisional khas...",
      options: ["Malaysia", "Indonesia", "Filipina", "Kamboja"],
      answer: "Malaysia"
    },
    { 
      question: "Roneat Ek adalah xilofon kayu tradisional dari negara...",
      options: ["Laos", "Kamboja", "Thailand", "Vietnam"],
      answer: "Kamboja"
    },
    { 
      question: "Dan Tranh adalah zither dengan berapa senar khas Vietnam?",
      options: ["8 senar", "12 senar", "16 senar", "20 senar"],
      answer: "16 senar"
    },
    { 
      question: "Pat Waing adalah drum melingkar tradisional khas negara...",
      options: ["Thailand", "Myanmar", "Laos", "Filipina"],
      answer: "Myanmar"
    }
  ]
};

const flags = { Thailand: "🇹🇭", Vietnam: "🇻🇳", Filipina: "🇵🇭", Indonesia: "🇮🇩", Myanmar: "🇲🇲" };
let scores = { l1: 0, l2: 0, l3: 0 };
let l2Selected = { term: null, def: null };

// --- Config ---
const defaultConfig = {
  game_title: "Alat Musik ASEAN",
  background_color: "#0f172a",
  surface_color: "#1e293b",
  text_color: "#e2e8f0",
  accent_color: "#f59e0b",
  muted_color: "#94a3b8",
  font_family: "Outfit",
  font_size: 16
};

function applyConfig(config) {
  const bg = config.background_color || defaultConfig.background_color;
  const surface = config.surface_color || defaultConfig.surface_color;
  const text = config.text_color || defaultConfig.text_color;
  const accent = config.accent_color || defaultConfig.accent_color;
  const muted = config.muted_color || defaultConfig.muted_color;
  const font = config.font_family || defaultConfig.font_family;
  const size = config.font_size || defaultConfig.font_size;
  const title = config.game_title || defaultConfig.game_title;

  document.getElementById('app').style.background = bg;
  document.getElementById('title-text').textContent = title;
  document.getElementById('title-text').style.color = accent;
  document.body.style.fontFamily = `${font}, Outfit, sans-serif`;
  document.body.style.fontSize = size + 'px';

  // Apply accent to all accent-colored elements
  document.querySelectorAll('[style*="color: #f59e0b"], [style*="color:#f59e0b"]').forEach(el => el.style.color = accent);
  document.querySelectorAll('[style*="background: #f59e0b"], [style*="background:#f59e0b"]').forEach(el => {
    el.style.background = accent;
  });
  document.querySelectorAll('[style*="background: #1e293b"], [style*="background:#1e293b"]').forEach(el => el.style.background = surface);
  document.querySelectorAll('[style*="color: #94a3b8"], [style*="color:#94a3b8"]').forEach(el => el.style.color = muted);
  document.querySelectorAll('[style*="color: #e2e8f0"], [style*="color:#e2e8f0"]').forEach(el => el.style.color = text);
}

window.elementSdk.init({
  defaultConfig,
  onConfigChange: async (config) => applyConfig(config),
  mapToCapabilities: (config) => ({
    recolorables: [
      { get: () => config.background_color || defaultConfig.background_color, set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
      { get: () => config.surface_color || defaultConfig.surface_color, set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
      { get: () => config.text_color || defaultConfig.text_color, set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
      { get: () => config.accent_color || defaultConfig.accent_color, set: (v) => { config.accent_color = v; window.elementSdk.setConfig({ accent_color: v }); } },
      { get: () => config.muted_color || defaultConfig.muted_color, set: (v) => { config.muted_color = v; window.elementSdk.setConfig({ muted_color: v }); } }
    ],
    borderables: [],
    fontEditable: { get: () => config.font_family || defaultConfig.font_family, set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); } },
    fontSizeable: { get: () => config.font_size || defaultConfig.font_size, set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); } }
  }),
  mapToEditPanelValues: (config) => new Map([
    ["game_title", config.game_title || defaultConfig.game_title]
  ])
});

// --- Toast ---
function showToast(msg, type) {
  const t = document.getElementById('toast');
  const inner = document.getElementById('toast-inner');
  inner.textContent = msg;
  inner.style.background = type === 'success' ? '#22c55e' : type === 'error' ? '#ef4444' : '#f59e0b';
  t.classList.remove('hidden');
  setTimeout(() => t.classList.add('hidden'), 1800);
}

// --- Screen Nav ---
function showScreen(name) {
  document.querySelectorAll('#app > div[id^="screen-"]').forEach(s => s.classList.add('hidden'));
  document.getElementById('screen-' + name).classList.remove('hidden');
  if (name === 'result') showResult();
  lucide.createIcons();
}

// --- Materi ---
function renderMateri() {
  const el = document.getElementById('materi-list');
  el.innerHTML = gameData.materi.map(m => `
    <div class="materi-card rounded-xl p-5 flex items-center gap-4" style="background: #1e293b; border: 1px solid #334155;">
      <span class="text-3xl">${flags[m.negara] || '🎶'}</span>
      <div>
        <p class="font-bold text-lg" style="color: #e2e8f0;">${m.alat}</p>
        <p class="text-sm" style="color: #94a3b8;">${m.negara} · ${m.jenis}</p>
      </div>
    </div>
  `).join('');
}

// --- Level 1: Drag & Drop ---
function renderLevel1() {
  scores.l1 = 0;
  const items = document.getElementById('l1-items');
  const targets = document.getElementById('l1-targets');
  document.getElementById('l1-next').classList.add('hidden');
  updateL1Score();

  const shuffled = [...gameData.level1].sort(() => Math.random() - 0.5);
  items.innerHTML = shuffled.map(d => `
    <div class="drag-item px-5 py-3 rounded-xl font-semibold" draggable="true" data-item="${d.item}"
      style="background: #f59e0b; color: #0f172a;" 
      ontouchstart="handleTouchStart(event)" ontouchmove="handleTouchMove(event)" ontouchend="handleTouchEnd(event)">
      🎵 ${d.item}
    </div>
  `).join('');

  targets.innerHTML = gameData.level1.map(d => `
    <div class="drop-zone rounded-xl p-5 flex items-center justify-between" data-target="${d.target}"
      style="border: 2px dashed #334155; background: #1e293b; min-height: 64px;">
      <span class="font-semibold" style="color: #e2e8f0;">${flags[d.target] || ''} ${d.target}</span>
      <span class="text-sm" style="color: #64748b;">Seret ke sini</span>
    </div>
  `).join('');

  // Desktop drag
  items.querySelectorAll('.drag-item').forEach(el => {
    el.addEventListener('dragstart', e => { e.dataTransfer.setData('text/plain', el.dataset.item); el.classList.add('dragging'); });
    el.addEventListener('dragend', () => el.classList.remove('dragging'));
  });
  targets.querySelectorAll('.drop-zone').forEach(zone => {
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
      e.preventDefault(); zone.classList.remove('drag-over');
      const item = e.dataTransfer.getData('text/plain');
      checkL1Drop(item, zone);
    });
  });
}

// Touch support for drag
let touchDragItem = null;
function handleTouchStart(e) {
  touchDragItem = e.target.closest('.drag-item');
  touchDragItem.classList.add('dragging');
}
function handleTouchMove(e) { e.preventDefault(); }
function handleTouchEnd(e) {
  if (!touchDragItem) return;
  touchDragItem.classList.remove('dragging');
  const touch = e.changedTouches[0];
  const dropEl = document.elementFromPoint(touch.clientX, touch.clientY);
  const zone = dropEl?.closest('.drop-zone');
  if (zone) checkL1Drop(touchDragItem.dataset.item, zone);
  touchDragItem = null;
}

function checkL1Drop(item, zone) {
  const match = gameData.level1.find(d => d.item === item && d.target === zone.dataset.target);
  if (match) {
    zone.classList.add('correct');
    zone.innerHTML = `<span class="font-semibold" style="color: #22c55e;">${flags[match.target]} ${match.target}</span><span class="font-bold" style="color: #22c55e;">✓ ${match.item}</span>`;
    zone.style.pointerEvents = 'none';
    // Remove dragged item
    document.querySelector(`.drag-item[data-item="${item}"]`)?.remove();
    scores.l1++;
    updateL1Score();
    showToast('Benar! 🎉', 'success');
    if (scores.l1 === gameData.level1.length) {
      setTimeout(() => document.getElementById('l1-next').classList.remove('hidden'), 600);
    }
  } else {
    zone.classList.add('wrong');
    setTimeout(() => zone.classList.remove('wrong'), 400);
    showToast('Coba lagi!', 'error');
  }
}

function updateL1Score() {
  document.getElementById('l1-score').textContent = `${scores.l1}/${gameData.level1.length}`;
  document.getElementById('l1-progress').style.width = `${(scores.l1 / gameData.level1.length) * 100}%`;
}

// --- Level 2: Matching ---
function renderLevel2() {
  scores.l2 = 0;
  l2Selected = { term: null, def: null };
  document.getElementById('l2-next').classList.add('hidden');
  updateL2Score();

  const terms = document.getElementById('l2-terms');
  const defs = document.getElementById('l2-defs');
  const shuffledDefs = [...gameData.level2].sort(() => Math.random() - 0.5);

  terms.innerHTML = gameData.level2.map(d => `
    <div class="match-card rounded-xl p-4 text-center font-semibold" data-term="${d.term}" onclick="selectTerm(this)"
      style="background: #1e293b; border: 2px solid #334155; color: #e2e8f0;">
      🎵 ${d.term}
    </div>
  `).join('');

  defs.innerHTML = shuffledDefs.map(d => `
    <div class="match-card rounded-xl p-4 text-center font-semibold" data-def="${d.definition}" onclick="selectDef(this)"
      style="background: #1e293b; border: 2px solid #334155; color: #e2e8f0;">
      ${flags[d.definition] || ''} ${d.definition}
    </div>
  `).join('');
}

function selectTerm(el) {
  if (el.classList.contains('matched')) return;
  document.querySelectorAll('#l2-terms .match-card').forEach(c => c.style.boxShadow = '');
  el.style.boxShadow = '0 0 0 3px #f59e0b';
  l2Selected.term = el.dataset.term;
  tryMatch();
}
function selectDef(el) {
  if (el.classList.contains('matched')) return;
  document.querySelectorAll('#l2-defs .match-card').forEach(c => c.style.boxShadow = '');
  el.style.boxShadow = '0 0 0 3px #f59e0b';
  l2Selected.def = el.dataset.def;
  tryMatch();
}
function tryMatch() {
  if (!l2Selected.term || !l2Selected.def) return;
  const match = gameData.level2.find(d => d.term === l2Selected.term && d.definition === l2Selected.def);
  if (match) {
    document.querySelector(`[data-term="${match.term}"]`).classList.add('matched');
    document.querySelector(`[data-def="${match.definition}"]`).classList.add('matched');
    document.querySelector(`[data-term="${match.term}"]`).style.boxShadow = '';
    document.querySelector(`[data-def="${match.definition}"]`).style.boxShadow = '';
    scores.l2++;
    updateL2Score();
    showToast('Cocok! 🎉', 'success');
    if (scores.l2 === gameData.level2.length) {
      setTimeout(() => document.getElementById('l2-next').classList.remove('hidden'), 600);
    }
  } else {
    showToast('Tidak cocok, coba lagi!', 'error');
  }
  l2Selected = { term: null, def: null };
  document.querySelectorAll('.match-card:not(.matched)').forEach(c => c.style.boxShadow = '');
}
function updateL2Score() {
  document.getElementById('l2-score').textContent = `${scores.l2}/${gameData.level2.length}`;
  document.getElementById('l2-progress').style.width = `${(scores.l2 / gameData.level2.length) * 100}%`;
}

// --- Level 3: Multiple Choice ---
function renderLevel3() {
  scores.l3 = 0;
  document.getElementById('l3-next').classList.add('hidden');
  updateL3Score();

  const container = document.getElementById('l3-questions');
  container.innerHTML = gameData.level3.map((q, qi) => `
    <div class="rounded-xl p-6 fade-up" style="background: #1e293b; border: 1px solid #334155;">
      <p class="font-semibold mb-4" style="color: #e2e8f0;">${qi + 1}. ${q.question}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        ${q.options.map(opt => `
          <button class="option-btn rounded-xl px-4 py-3 text-left font-medium" data-q="${qi}" data-opt="${opt}"
            style="background: #0f172a; border: 2px solid #334155; color: #e2e8f0;"
            onclick="checkL3(this, ${qi}, '${opt.replace(/'/g, "\\'")}')">${opt}</button>
        `).join('')}
      </div>
    </div>
  `).join('');
}

function checkL3(btn, qi, opt) {
  const q = gameData.level3[qi];
  const allBtns = document.querySelectorAll(`[data-q="${qi}"]`);
  allBtns.forEach(b => b.disabled = true);

  if (opt === q.answer) {
    btn.classList.add('correct-answer');
    scores.l3++;
    showToast('Benar! 🎉', 'success');
  } else {
    btn.classList.add('wrong-answer');
    allBtns.forEach(b => { if (b.dataset.opt === q.answer) b.classList.add('correct-answer'); });
    showToast('Jawaban salah!', 'error');
  }
  updateL3Score();
  setTimeout(() => document.getElementById('l3-next').classList.remove('hidden'), 800);
}

function updateL3Score() {
  document.getElementById('l3-score').textContent = `${scores.l3}/${gameData.level3.length}`;
  document.getElementById('l3-progress').style.width = `${(scores.l3 / gameData.level3.length) * 100}%`;
}

// --- Result ---
function showResult() {
  const total = gameData.level1.length + gameData.level2.length + gameData.level3.length;
  const got = scores.l1 + scores.l2 + scores.l3;
  const pct = Math.round((got / total) * 100);
  document.getElementById('result-score').textContent = `${got}/${total}`;
  const emoji = pct === 100 ? '🏆' : pct >= 60 ? '⭐' : '💪';
  const msg = pct === 100 ? 'Sempurna! Kamu ahli musik ASEAN!' : pct >= 60 ? 'Bagus! Terus belajar!' : 'Jangan menyerah, coba lagi!';
  document.getElementById('result-emoji').textContent = emoji;
  document.getElementById('result-msg').textContent = msg;
}

function startLevel(n) {
  showScreen('level' + n);
  if (n === 1) renderLevel1();
  if (n === 2) renderLevel2();
  if (n === 3) renderLevel3();
}

function resetGame() {
  scores = { l1: 0, l2: 0, l3: 0 };
  showScreen('start');
}

// Init
renderMateri();
lucide.createIcons();
</script>
