    { item: "Khaen", target: "Laos" },
    { item: "Saung Gauk", target: "Myanmar" },
    { item: "Chapei Dang Veng", target: "Kamboja" },
    { item: "Rebab", target: "Malaysia" }
  ],
  level2: [
    { term: "Gamelan", definition: "Indonesia" },
    { term: "Saung Gauk", definition: "Myanmar" },
    { term: "Chapei Dang Veng", definition: "Kamboja" },
    { term: "Ranat Ek", definition: "Thailand" },
    { term: "Khaen", definition: "Laos" },
    { term: "Dan Bau", definition: "Vietnam" },
    { term: "Kulintang", definition: "Filipina" },
    { term: "Khong Wong Yai", definition: "Laos" }
  ],
  level3: [
    { 
      question: "Alat musik petik khas Vietnam yang hanya memiliki satu senar disebut...",
      options: ["Dan Bau", "Khim", "Pin", "Piphat"],
      answer: "Dan Bau"
    },
