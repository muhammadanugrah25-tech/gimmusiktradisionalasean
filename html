  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body { font-family: 'Outfit', sans-serif; }

    .drag-item { cursor: grab; user-select: none; transition: transform 0.2s, box-shadow 0.2s; }
    .drag-item:active { cursor: grabbing; }
    .drag-item.dragging { opacity: 0.5; transform: scale(1.05); }
    .drop-zone { transition: background 0.2s, border-color 0.2s; }
    .drop-zone.drag-over { border-color: #f59e0b !important; background: rgba(245,158,11,0.1) !important; }
    .drop-zone.correct { border-color: #22c55e !important; background: rgba(34,197,94,0.12) !important; }
    .drop-zone.wrong { animation: shake 0.4s; }

    .match-card { cursor: pointer; transition: all 0.2s; }
    .match-card:hover { transform: translateY(-2px); }
    .match-card.selected { ring: 2px; box-shadow: 0 0 0 3px #f59e0b; }
    .match-card.matched { opacity: 0.5; pointer-events: none; border-color: #22c55e !important; }

    .option-btn { transition: all 0.15s; }
    .option-btn:hover:not(:disabled) { transform: translateY(-1px); }
    .option-btn.correct-answer { background: #22c55e !important; color: white !important; border-color: #22c55e !important; }
    .option-btn.wrong-answer { background: #ef4444 !important; color: white !important; border-color: #ef4444 !important; }

    @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.05)} }
    .fade-up { animation: fadeUp 0.5s ease-out both; }
    .pulse-anim { animation: pulse 1.5s infinite; }

    .materi-card { animation: fadeUp 0.5s ease-out both; }
    .materi-card:nth-child(1) { animation-delay: 0.1s; }
    .materi-card:nth-child(2) { animation-delay: 0.2s; }
    .materi-card:nth-child(3) { animation-delay: 0.3s; }

    .progress-fill { transition: width 0.6s ease; }
    .toast { animation: fadeUp 0.3s ease-out; }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
